{
  "version": "1.0.0",
  "name": "Noctua Tech Stack Evals",
  "scenarios": [
    {
      "id": "V001",
      "description": "Pergunta de tecnologia aparece antes do TSR",
      "assertion": "system_type field must be requested first"
    },
    {
      "id": "V005",
      "description": "IP + NVR PoE + 4 câmeras",
      "input": { "tech": "ip", "poe": "nvr_poe", "cameras": 4 },
      "output": { "recorder": "NVR 4 Canais PoE", "switch": null }
    },
    {
      "id": "V008",
      "description": "IP + Switch externo + 12 câmeras",
      "input": { "tech": "ip", "poe": "switch_poe", "cameras": 12 },
      "output": { "recorder": "NVR 16 Canais", "switch": "Switch PoE 16 portas" }
    },
    {
      "id": "V012",
      "description": "IP + 2MP + 80m",
      "input": { "tech": "ip", "res": "2MP", "dist": 80 },
      "output": { "cable": "UTP Cat5e", "alert": null }
    },
    {
      "id": "V013",
      "description": "IP + 2MP + 120m",
      "input": { "tech": "ip", "res": "2MP", "dist": 120 },
      "output": { "cable": "UTP Cat5e", "alert": "BLOCK_DISTÂNCIA_EXCEDIDA" }
    },
    {
      "id": "V019",
      "description": "Storage: 2TB, 8 câmeras 2MP",
      "input": { "hd": 2, "cameras": 8, "res": "2MP" },
      "output": { "min_days": 20, "max_days": 28 }
    }
  ]
}
